# Supabase – get these from your project's Settings → API page
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only – never expose this in the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin email – server-side only (NOT exposed to browser)
ADMIN_EMAIL=admin@example.com

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry Error Tracking (optional - for production)
# Get your DSN from https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# Google reCAPTCHA (for brute-force protection after failed login attempts)
# Get these from https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key-v3
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key-v3

# IP Whitelist for Admin Access (optional)
# Leave empty to disable (default)
# Add comma-separated IPs, CIDR ranges, or wildcards
# Examples:
#   - Single IP: ADMIN_IP_WHITELIST=192.168.1.100
#   - Multiple IPs: ADMIN_IP_WHITELIST=192.168.1.100,10.0.0.50
#   - CIDR range: ADMIN_IP_WHITELIST=10.0.0.0/24
#   - Wildcard: ADMIN_IP_WHITELIST=192.168.1.*
ADMIN_IP_WHITELIST=
