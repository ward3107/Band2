{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/manifest.webmanifest",
      "destination": "/api/manifest"
    }
  ],
  "headers": [
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
